# New Central Portal — environment configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Every value here is read by docker-compose.yml and passed to the app
# container. All integrations degrade gracefully: leave a section blank and
# the related features are disabled (or fall back to mock data) instead of
# crashing the app.

# ── Database ──────────────────────────────────────────────────────────────────
# Password for the bundled PostgreSQL service (user/db are both "netlab").
# docker-compose.yml derives DATABASE_URL from this automatically. Change it
# for anything beyond local development.
POSTGRES_PASSWORD=netlab

# If you run the app OUTSIDE docker compose (e.g. local uvicorn), point it at
# your own PostgreSQL instead. Inside compose this is set for you.
# DATABASE_URL=postgresql://netlab:netlab@localhost:5432/netlab

# ── Aruba Central (New Central) ───────────────────────────────────────────────
# API gateway base URL and access token for HPE Aruba Networking Central.
# Leave blank to browse the UI with mock data.
ARUBA_CENTRAL_BASE_URL=https://apigw-prod2.central.arubanetworks.com
ARUBA_CENTRAL_ACCESS_TOKEN=

# ── Classic Central ───────────────────────────────────────────────────────────
# OAuth2 credentials for the Classic Central gateway. Used for group/site
# management (device assignment) and site lookups. Without these, those
# features are unavailable but everything else still works.
CLASSIC_CENTRAL_BASE_URL=https://internal-apigw.central.arubanetworks.com
CLASSIC_CENTRAL_CLIENT_ID=
CLASSIC_CENTRAL_CLIENT_SECRET=
# Optional: seed tokens. The app refreshes the access token automatically as
# long as a valid refresh token is available.
CLASSIC_CENTRAL_ACCESS_TOKEN=
CLASSIC_CENTRAL_REFRESH_TOKEN=

# ── GreenLake / centralmcp bridge ─────────────────────────────────────────────
# Host path to your centralmcp checkout. It is mounted read-only into the app
# container at /centralmcp and provides the MCP tools, GreenLake (GLP) client,
# credentials.yaml, and the LanceDB doc-search index used by the Lab.
CENTRALMCP_PATH=./centralmcp

# Allow GLP v2beta1 write operations (subscription/device assignment) through
# the bridge. Set to 0 to force read-only GreenLake access.
CENTRALMCP_GLP_V2BETA1_WRITES=1

# ── Auth / Session ────────────────────────────────────────────────────────────
# Single shared password for the portal login page.
# IMPORTANT: leave empty and authentication is DISABLED — anyone who can reach
# the portal can view and manage devices (including reboots).
PORTAL_PASSWORD=

# Secret used to sign session cookies. If unset, an ephemeral secret is
# generated at startup and every restart logs all users out.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=

# How long a login session stays valid, in hours.
SESSION_MAX_AGE_HOURS=24

# ── Alerting / Email ──────────────────────────────────────────────────────────
# How often (seconds) the device-down alert engine polls device status.
# Minimum enforced at runtime is 15.
DEVICE_CHECK_INTERVAL_SECONDS=60

# Maximum number of devices fetched per status poll.
DEVICE_FETCH_LIMIT=1000

# Note: SMTP settings (host, port, credentials, recipients) are configured in
# the UI under Notifications and stored in the database — not here.

# ── LLM / GitHub Models ───────────────────────────────────────────────────────
# GitHub personal access token. Powers the AI assistant drawer and the Lab
# chatbot via the GitHub Models (OpenAI-compatible) endpoint.
GITHUB_TOKEN=

# Anthropic API key (reserved for Claude-backed experiments).
ANTHROPIC_API_KEY=

# ── RAG backends (Lab → Doc Search / Chatbot context) ─────────────────────────
# Doc search uses centralmcp's embedded LanceDB index by default (no servers
# needed beyond the centralmcp mount). For the optional Redis Stack backend,
# set CENTRALMCP_RAG_BACKEND=redis inside the app container and run Ollama:
OLLAMA_URL=http://host.docker.internal:11434

# ── Misc ──────────────────────────────────────────────────────────────────────
# Python logging level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Set to 1 after running scripts/build-tailwind.sh to serve pre-built CSS
# instead of the vendored Tailwind Play CDN runtime (faster loads, offline-safe).
# USE_BUILT_TAILWIND=1
