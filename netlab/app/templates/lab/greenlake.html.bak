{% extends "base.html" %}
{% block title %}GreenLake - New Central Portal{% endblock %}
{% block content %}
<div class="page-header flex items-end justify-between">
    <div>
        <p class="text-xs text-gray-500 uppercase tracking-widest mb-1">Platform</p>
        <h1 class="text-2xl font-bold text-white">HPE GreenLake</h1>
        <p class="text-sm text-gray-500 mt-0.5">Inventory, subscriptions, users, and audit from GLP workspace</p>
    </div>
    <!-- summary pills -->
    <div style="display:flex;gap:8px;">
        {% for label, count, color in [('Devices', devices|length, '#6366f1'), ('Subscriptions', subscriptions|length, '#10b981'), ('Users', users|length, '#3b82f6')] %}
        <div style="padding:6px 14px;background:{{ color }}18;border:1px solid {{ color }}40;border-radius:20px;font-size:.72rem;color:{{ color }};font-weight:700;">
            {{ count }} {{ label }}
        </div>
        {% endfor %}
    </div>
</div>

<div x-data="{tab:'devices'}" style="margin-top:0;">

    <!-- Tab bar -->
    <div style="display:flex;align-items:stretch;border-bottom:1px solid #1e2535;">
        <button @click="tab='devices'"
            :style="tab==='devices' ? 'color:#f97316;box-shadow:inset 0 -2px 0 #f97316;' : 'color:#6b7280;box-shadow:none;'"
            style="display:inline-flex;align-items:center;gap:8px;padding:10px 24px 10px 0;font-size:.82rem;font-weight:600;background:none;border:none;cursor:pointer;transition:color .15s;white-space:nowrap;">
            Devices
            <span :style="tab==='devices' ? 'background:rgba(249,115,22,.18);color:#f97316;' : 'background:#232b3b;color:#94a3b8;'"
                  style="padding:2px 8px;border-radius:20px;font-size:.68rem;font-weight:700;line-height:1.4;">{{ devices|length }}</span>
        </button>
        <div style="width:1px;background:#1e2535;margin:8px 20px;"></div>
        <button @click="tab='subscriptions'"
            :style="tab==='subscriptions' ? 'color:#f97316;box-shadow:inset 0 -2px 0 #f97316;' : 'color:#6b7280;box-shadow:none;'"
            style="display:inline-flex;align-items:center;gap:8px;padding:10px 0;font-size:.82rem;font-weight:600;background:none;border:none;cursor:pointer;transition:color .15s;white-space:nowrap;">
            Subscriptions
            <span :style="tab==='subscriptions' ? 'background:rgba(249,115,22,.18);color:#f97316;' : 'background:#232b3b;color:#94a3b8;'"
                  style="padding:2px 8px;border-radius:20px;font-size:.68rem;font-weight:700;line-height:1.4;">{{ subscriptions|length }}</span>
        </button>
        <div style="width:1px;background:#1e2535;margin:8px 20px;"></div>
        <button @click="tab='users'"
            :style="tab==='users' ? 'color:#f97316;box-shadow:inset 0 -2px 0 #f97316;' : 'color:#6b7280;box-shadow:none;'"
            style="display:inline-flex;align-items:center;gap:8px;padding:10px 0;font-size:.82rem;font-weight:600;background:none;border:none;cursor:pointer;transition:color .15s;white-space:nowrap;">
            Users
            <span :style="tab==='users' ? 'background:rgba(249,115,22,.18);color:#f97316;' : 'background:#232b3b;color:#94a3b8;'"
                  style="padding:2px 8px;border-radius:20px;font-size:.68rem;font-weight:700;line-height:1.4;">{{ users|length }}</span>
        </button>
        <div style="width:1px;background:#1e2535;margin:8px 20px;"></div>
        <button @click="tab='audit'"
            :style="tab==='audit' ? 'color:#f97316;box-shadow:inset 0 -2px 0 #f97316;' : 'color:#6b7280;box-shadow:none;'"
            style="display:inline-flex;align-items:center;gap:8px;padding:10px 0;font-size:.82rem;font-weight:600;background:none;border:none;cursor:pointer;transition:color .15s;white-space:nowrap;">
            Audit Log
            <span :style="tab==='audit' ? 'background:rgba(249,115,22,.18);color:#f97316;' : 'background:#232b3b;color:#94a3b8;'"
                  style="padding:2px 8px;border-radius:20px;font-size:.68rem;font-weight:700;line-height:1.4;">{{ audit_logs|length }}</span>
        </button>
    </div>


    <!-- subscriptions data for Alpine (avoids JSON-in-attribute issues) -->
    <script id="glp-subs-json" type="application/json">{{ subscriptions | tojson }}</script>

    <!-- Shared sort helper for all tabs -->
    <script>
    function glpSortMixin() {
        return {
            sortCol: -1,
            sortDir: 1,
            doSort(col, tableEl) {
                if (this.sortCol === col) this.sortDir *= -1;
                else { this.sortCol = col; this.sortDir = 1; }
                const tbody = tableEl.querySelector('tbody');
                const rows = Array.from(tbody.querySelectorAll('tr'));
                rows.sort((a, b) => {
                    const av = (a.dataset['sort' + col] || '').toLowerCase();
                    const bv = (b.dataset['sort' + col] || '').toLowerCase();
                    if (av < bv) return -1 * this.sortDir;
                    if (av > bv) return 1 * this.sortDir;
                    return 0;
                });
                rows.forEach(r => tbody.appendChild(r));
            },
            sortIcon(col) {
                if (this.sortCol !== col) return ' ↕';
                return this.sortDir === 1 ? ' ↑' : ' ↓';
            }
        };
    }
    </script>

    <!-- ── Devices tab ── -->
    <div x-show="tab==='devices'" x-data="{
        search:'',
        ...glpSortMixin(),
        modal: false,
        mSerial: '',
        mDeviceType: '',
        mCurrentKey: '',
        mNewKey: '',
        mBusy: false,
        mError: '',
        mSuccess: '',
        allSubs: JSON.parse(document.getElementById('glp-subs-json').textContent),
        get filteredSubs() {
            const dt = (this.mDeviceType || '').toUpperCase();
            let match = '';
            if (['IAP','AP','ACCESS_POINT'].some(t => dt.includes(t))) match = 'AP';
            else if (['SWITCH','CX'].some(t => dt.includes(t))) match = 'SWITCH';
            else if (['GATEWAY','GW','VPNC'].some(t => dt.includes(t))) match = 'GATEWAY';
            if (!match) return this.allSubs;
            return this.allSubs.filter(s => {
                const st = ((s.subscriptionType || '') + ' ' + (s.tier || '')).toUpperCase();
                return st.includes(match);
            });
        },
        openModal(serial, currentKey, deviceType) {
            this.mSerial = serial;
            this.mCurrentKey = currentKey;
            this.mDeviceType = deviceType;
            this.mNewKey = '';
            this.mError = '';
            this.mSuccess = '';
            this.mBusy = false;
            this.modal = true;
        },
        async doAssign() {
            if (!this.mNewKey) { this.mError = 'Select a subscription'; return; }
            this.mBusy = true; this.mError = '';
            try {
                const r = await fetch('/lab/greenlake/assign-subscription', {
                    method: 'POST',
                    headers: {'Content-Type':'application/json'},
                    body: JSON.stringify({serial_number: this.mSerial, subscription_key: this.mNewKey})
                });
                const j = await r.json();
                if (j.ok) { this.mSuccess = 'Assigned — refreshing page…'; setTimeout(() => location.reload(), 3000); }
                else { this.mError = j.error || 'Failed'; }
            } catch(e) { this.mError = e.message; }
            this.mBusy = false;
        },
        async doUnassign() {
            if (!confirm('Remove subscription from ' + this.mSerial + '?')) return;
            this.mBusy = true; this.mError = '';
            try {
                const r = await fetch('/lab/greenlake/unassign-subscription', {
                    method: 'POST',
                    headers: {'Content-Type':'application/json'},
                    body: JSON.stringify({serial_number: this.mSerial})
                });
                const j = await r.json();
                if (j.ok) { this.mSuccess = 'Unassigned — refreshing page…'; setTimeout(() => location.reload(), 3000); }
                else { this.mError = j.error || 'Failed'; }
            } catch(e) { this.mError = e.message; }
            this.mBusy = false;
        }
    }" class="card" style="padding:0;overflow:hidden;border-top-left-radius:0;border-top-right-radius:0;">

        <!-- Reassignment modal overlay -->
        <div x-show="modal" x-cloak @click.self="modal=false"
             style="position:fixed;inset:0;z-index:100;background:rgba(0,0,0,.6);display:flex;align-items:center;justify-content:center;">
            <div @click.stop style="background:#141922;border:1px solid #1e2535;border-radius:12px;padding:24px;width:440px;max-width:90vw;">
                <h3 style="font-size:.9rem;font-weight:700;color:#f1f5f9;margin:0 0 4px;">Reassign Subscription</h3>
                <p style="font-size:.72rem;color:#6b7280;margin:0 0 16px;">Device: <span style="color:#f97316;font-family:monospace;" x-text="mSerial"></span></p>

                <p style="font-size:.65rem;text-transform:uppercase;letter-spacing:.08em;color:#6b7280;font-weight:700;margin:0 0 6px;">Current subscription</p>
                <p style="font-size:.78rem;color:#94a3b8;font-family:monospace;margin:0 0 16px;word-break:break-all;" x-text="mCurrentKey || '— none —'"></p>

                <label style="font-size:.65rem;text-transform:uppercase;letter-spacing:.08em;color:#6b7280;font-weight:700;display:block;margin:0 0 6px;">Assign new subscription <span style="font-weight:400;text-transform:none;letter-spacing:0;" x-text="mDeviceType ? '(' + mDeviceType + ' compatible)' : ''"></span></label>
                <select x-model="mNewKey" style="width:100%;padding:8px 12px;background:#0d1117;border:1px solid #1e2535;border-radius:6px;color:#e2e8f0;font-size:.78rem;font-family:monospace;outline:none;margin:0 0 6px;">
                    <option value="">— select —</option>
                    <template x-for="s in filteredSubs" :key="s.key">
                        <option :value="s.key" x-text="s.key + ' · ' + (s.tier || s.subscriptionType || '') + ' (' + (s.availableQuantity || '0') + ' avail)'"></option>
                    </template>
                </select>
                <p x-show="filteredSubs.length === 0" style="font-size:.72rem;color:#f87171;margin:0 0 12px;">No matching subscriptions found for this device type.</p>
                <p x-show="filteredSubs.length > 0" style="font-size:.6rem;color:#4b5563;margin:0 0 16px;">Only subscriptions with available quantity will succeed.</p>

                <!-- status messages -->
                <p x-show="mError" style="font-size:.75rem;color:#f87171;margin:0 0 10px;" x-text="mError"></p>
                <p x-show="mSuccess" style="font-size:.75rem;color:#4ade80;margin:0 0 10px;" x-text="mSuccess"></p>

                <div style="display:flex;gap:8px;justify-content:flex-end;">
                    <button @click="doUnassign()" :disabled="mBusy || !mCurrentKey"
                        style="padding:7px 14px;border:1px solid #7f1d1d;border-radius:6px;background:#7f1d1d30;color:#f87171;font-size:.75rem;font-weight:600;cursor:pointer;"
                        :style="mBusy && {opacity:.5,cursor:'wait'}">Unassign</button>
                    <button @click="modal=false" style="padding:7px 14px;border:1px solid #1e2535;border-radius:6px;background:none;color:#94a3b8;font-size:.75rem;cursor:pointer;">Cancel</button>
                    <button @click="doAssign()" :disabled="mBusy || !mNewKey"
                        style="padding:7px 14px;border:none;border-radius:6px;background:#f97316;color:#fff;font-size:.75rem;font-weight:700;cursor:pointer;"
                        :style="mBusy && {opacity:.5,cursor:'wait'}">Assign</button>
                </div>
            </div>
        </div>

        <div style="padding:14px 20px;border-bottom:1px solid #1e2535;display:flex;align-items:center;gap:12px;">
            <p style="font-size:.65rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#6b7280;flex:1;">{{ devices|length }} devices</p>
            <div style="position:relative;">
                <svg style="position:absolute;left:10px;top:50%;transform:translateY(-50%);" width="13" height="13" fill="none" stroke="#6b7280" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="M21 21l-4.35-4.35"/></svg>
                <input x-model="search" type="text" placeholder="Filter…" style="padding:6px 12px 6px 30px;background:#0d1117;border:1px solid #1e2535;border-radius:6px;color:#e2e8f0;font-size:.8rem;outline:none;width:200px;">
            </div>
        </div>
        {% if devices %}
        <table x-ref="devTable" style="width:100%;border-collapse:collapse;">
            <thead><tr style="background:#0d1117;">
                {% for col_i, h in [(0,'Serial'),(1,'Part Number'),(2,'Type'),(3,'Subscription Key'),(4,'Expiry'),(5,'Status')] %}
                <th @click="doSort({{ col_i }}, $refs.devTable)" style="padding:9px 20px;text-align:left;font-size:.65rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#6b7280;cursor:pointer;user-select:none;white-space:nowrap;">{{ h }}<span style="font-size:.6rem;opacity:.6;" x-text="sortIcon({{ col_i }})"></span></th>
                {% endfor %}
            </tr></thead>
            <tbody>
            {% for d in devices %}
            {% set serial = d.get('serialNumber') or '—' %}
            {% set part = d.get('partNumber') or '—' %}
            {% set dtype = d.get('deviceType') or '—' %}
            {% set subkey = d.get('_sub_key') or '—' %}
            {% set sub_tier = d.get('_sub_tier') or '' %}
            {% set expiry = (d.get('_sub_end') or '')[:10] %}
            {% set status = d.get('_status') or '—' %}
            <tr class="tbl-row"
                data-search="{{ (serial ~ ' ' ~ part ~ ' ' ~ dtype ~ ' ' ~ subkey) | lower }}"
                data-sort-0="{{ serial }}" data-sort-1="{{ part }}" data-sort-2="{{ dtype }}" data-sort-3="{{ subkey }}" data-sort-4="{{ expiry }}" data-sort-5="{{ status }}"
                x-show="search==='' || $el.dataset.search.includes(search.toLowerCase())">
                <td style="padding:10px 20px;font-size:.78rem;color:#f1f5f9;font-weight:600;font-family:monospace;">{{ serial }}</td>
                <td style="padding:10px 20px;font-size:.75rem;color:#94a3b8;">{{ part }}</td>
                <td style="padding:10px 20px;font-size:.75rem;color:#94a3b8;">{{ dtype }}</td>
                <td style="padding:10px 20px;font-family:monospace;cursor:pointer;" @click="openModal('{{ serial }}', '{{ subkey if subkey != '—' else '' }}', '{{ dtype }}')">
                    {% if subkey != '—' %}
                    <span style="font-size:.72rem;color:#e2e8f0;border-bottom:1px dashed #6b7280;">{{ subkey }}</span>
                    {% if sub_tier %}<br><span style="font-size:.62rem;color:#6b7280;">{{ sub_tier }}</span>{% endif %}
                    {% else %}<span style="font-size:.72rem;color:#f97316;border-bottom:1px dashed #f97316;">+ assign</span>{% endif %}
                </td>
                <td style="padding:10px 20px;font-size:.72rem;font-family:monospace;color:{% if expiry and expiry < '2026-12-01' %}#f87171{% else %}#4ade80{% endif %};">{{ expiry or '—' }}</td>
                <td style="padding:10px 20px;">
                    {% set s = (status or '').lower() %}
                    <span style="display:inline-block;padding:2px 8px;border-radius:4px;font-size:.68rem;font-weight:700;
                        {% if 'assigned' in s %}color:#4ade80;background:#4ade8018;
                        {% elif 'arch' in s %}color:#6b7280;background:#6b728018;
                        {% else %}color:#94a3b8;background:#94a3b818;{% endif %}">
                        {{ status | replace('_',' ') | title }}</span>
                </td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
        {% else %}
        <p style="padding:32px 20px;color:#4b5563;font-size:.85rem;text-align:center;">No devices returned — GreenLake may not be configured or credentials are missing.</p>
        {% endif %}
    </div>

    <!-- ── Subscriptions tab ── -->
    <div x-show="tab==='subscriptions'" x-data="{search:'', ...glpSortMixin()}" class="card" style="padding:0;overflow:hidden;border-top-left-radius:0;border-top-right-radius:0;">
        <div style="padding:14px 20px;border-bottom:1px solid #1e2535;display:flex;align-items:center;gap:12px;">
            <p style="font-size:.65rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#6b7280;flex:1;">{{ subscriptions|length }} subscriptions</p>
            <div style="position:relative;">
                <svg style="position:absolute;left:10px;top:50%;transform:translateY(-50%);" width="13" height="13" fill="none" stroke="#6b7280" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="M21 21l-4.35-4.35"/></svg>
                <input x-model="search" type="text" placeholder="Filter…" style="padding:6px 12px 6px 30px;background:#0d1117;border:1px solid #1e2535;border-radius:6px;color:#e2e8f0;font-size:.8rem;outline:none;width:200px;">
            </div>
        </div>
        {% if subscriptions %}
        <table x-ref="subTable" style="width:100%;border-collapse:collapse;">
            <thead><tr style="background:#0d1117;">
                {% for col_i, h in [(0,'Key'),(1,'Type'),(2,'Qty'),(3,'Available'),(4,'Start'),(5,'Expiry')] %}
                <th @click="doSort({{ col_i }}, $refs.subTable)" style="padding:9px 20px;text-align:left;font-size:.65rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#6b7280;cursor:pointer;user-select:none;white-space:nowrap;">{{ h }}<span style="font-size:.6rem;opacity:.6;" x-text="sortIcon({{ col_i }})"></span></th>
                {% endfor %}
            </tr></thead>
            <tbody>
            {% for s in subscriptions %}
            {% set key = s.get('key') or '—' %}
            {% set stype = s.get('subscriptionType') or '—' %}
            {% set tier = s.get('tier') or '' %}
            {% set qty = s.get('quantity') or '—' %}
            {% set avail = s.get('availableQuantity') or '—' %}
            {% set start = (s.get('startTime') or '')[:10] %}
            {% set expiry = (s.get('endTime') or '')[:10] %}
            {% set sub_status = s.get('subscriptionStatus') or '' %}
            <tr class="tbl-row"
                data-search="{{ (key ~ ' ' ~ stype ~ ' ' ~ tier) | lower }}"
                data-sort-0="{{ key }}" data-sort-1="{{ stype }}" data-sort-2="{{ qty }}" data-sort-3="{{ avail }}" data-sort-4="{{ start }}" data-sort-5="{{ expiry }}"
                x-show="search==='' || $el.dataset.search.includes(search.toLowerCase())">
                <td style="padding:10px 20px;font-family:monospace;">
                    <span style="font-size:.72rem;color:#f1f5f9;font-weight:600;">{{ key }}</span>
                    {% if sub_status %}<br><span style="font-size:.6rem;font-weight:700;color:{% if sub_status == 'STARTED' %}#4ade80{% else %}#6b7280{% endif %};">{{ sub_status }}</span>{% endif %}
                </td>
                <td style="padding:10px 20px;">
                    <span style="font-size:.75rem;color:#94a3b8;">{{ stype }}</span>
                    {% if tier %}<br><span style="font-size:.62rem;color:#6b7280;">{{ tier }}</span>{% endif %}
                </td>
                <td style="padding:10px 20px;font-size:.8rem;color:#f97316;font-weight:700;">{{ qty }}</td>
                <td style="padding:10px 20px;font-size:.8rem;color:{% if avail != '—' and avail|string != '0' %}#4ade80{% else %}#6b7280{% endif %};">{{ avail }}</td>
                <td style="padding:10px 20px;font-size:.72rem;color:#6b7280;font-family:monospace;">{{ start or '—' }}</td>
                <td style="padding:10px 20px;font-size:.72rem;font-family:monospace;color:{% if expiry and expiry < '2026-12-01' %}#f87171{% else %}#4ade80{% endif %};">{{ expiry or '—' }}</td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
        {% else %}
        <p style="padding:32px 20px;color:#4b5563;font-size:.85rem;text-align:center;">No subscriptions found.</p>
        {% endif %}
    </div>

    <!-- ── Users tab ── -->
    <div x-show="tab==='users'" x-data="{search:'', ...glpSortMixin()}" class="card" style="padding:0;overflow:hidden;border-top-left-radius:0;border-top-right-radius:0;">
        <div style="padding:14px 20px;border-bottom:1px solid #1e2535;display:flex;align-items:center;gap:12px;">
            <p style="font-size:.65rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#6b7280;flex:1;">{{ users|length }} users</p>
            <div style="position:relative;">
                <svg style="position:absolute;left:10px;top:50%;transform:translateY(-50%);" width="13" height="13" fill="none" stroke="#6b7280" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="M21 21l-4.35-4.35"/></svg>
                <input x-model="search" type="text" placeholder="Filter…" style="padding:6px 12px 6px 30px;background:#0d1117;border:1px solid #1e2535;border-radius:6px;color:#e2e8f0;font-size:.8rem;outline:none;width:200px;">
            </div>
        </div>
        {% if users %}
        <table x-ref="userTable" style="width:100%;border-collapse:collapse;">
            <thead><tr style="background:#0d1117;">
                {% for col_i, h in [(0,'Name'),(1,'Email'),(2,'Status'),(3,'Last Login')] %}
                <th @click="doSort({{ col_i }}, $refs.userTable)" style="padding:9px 20px;text-align:left;font-size:.65rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#6b7280;cursor:pointer;user-select:none;white-space:nowrap;">{{ h }}<span style="font-size:.6rem;opacity:.6;" x-text="sortIcon({{ col_i }})"></span></th>
                {% endfor %}
            </tr></thead>
            <tbody>
            {% for u in users %}
            {% set fname = u.get('firstName') or '' %}
            {% set lname = u.get('lastName') or '' %}
            {% set name = (fname ~ ' ' ~ lname).strip() or u.get('username') or '—' %}
            {% set email = u.get('username') or '—' %}
            {% set ustatus = u.get('userStatus') or '—' %}
            {% set last_login = (u.get('lastLogin') or '')[:16] | replace('T',' ') %}
            <tr class="tbl-row"
                data-search="{{ (name ~ ' ' ~ email ~ ' ' ~ ustatus) | lower }}"
                data-sort-0="{{ name }}" data-sort-1="{{ email }}" data-sort-2="{{ ustatus }}" data-sort-3="{{ last_login }}"
                x-show="search==='' || $el.dataset.search.includes(search.toLowerCase())">
                <td style="padding:10px 20px;font-size:.82rem;color:#f1f5f9;font-weight:500;">{{ name }}</td>
                <td style="padding:10px 20px;font-size:.78rem;color:#94a3b8;">{{ email }}</td>
                <td style="padding:10px 20px;">
                    {% set sv = (ustatus or '').lower() %}
                    <span style="display:inline-block;padding:2px 9px;border-radius:4px;font-size:.68rem;font-weight:700;
                        {% if 'verified' in sv %}color:#4ade80;background:#4ade8018;
                        {% elif 'invited' in sv %}color:#fbbf24;background:#fbbf2418;
                        {% else %}color:#6b7280;background:#6b728018;{% endif %}">{{ ustatus }}</span>
                </td>
                <td style="padding:10px 20px;font-size:.7rem;color:#4b5563;font-family:monospace;">{{ last_login or '—' }}</td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
        {% else %}
        <p style="padding:32px 20px;color:#4b5563;font-size:.85rem;text-align:center;">No users found.</p>
        {% endif %}
    </div>

    <!-- ── Audit Log tab ── -->
    <div x-show="tab==='audit'" x-data="{search:'', ...glpSortMixin()}" class="card" style="padding:0;overflow:hidden;border-top-left-radius:0;border-top-right-radius:0;">
        <div style="padding:14px 20px;border-bottom:1px solid #1e2535;display:flex;align-items:center;gap:12px;">
            <p style="font-size:.65rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#6b7280;flex:1;">{{ audit_logs|length }} log entries</p>
            <div style="position:relative;">
                <svg style="position:absolute;left:10px;top:50%;transform:translateY(-50%);" width="13" height="13" fill="none" stroke="#6b7280" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="M21 21l-4.35-4.35"/></svg>
                <input x-model="search" type="text" placeholder="Filter…" style="padding:6px 12px 6px 30px;background:#0d1117;border:1px solid #1e2535;border-radius:6px;color:#e2e8f0;font-size:.8rem;outline:none;width:200px;">
            </div>
        </div>
        {% if audit_logs %}
        <table x-ref="auditTable" style="width:100%;border-collapse:collapse;">
            <thead><tr style="background:#0d1117;">
                {% for col_i, h in [(0,'When'),(1,'User'),(2,'Category'),(3,'Application'),(4,'Description')] %}
                <th @click="doSort({{ col_i }}, $refs.auditTable)" style="padding:9px 20px;text-align:left;font-size:.65rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#6b7280;cursor:pointer;user-select:none;white-space:nowrap;">{{ h }}<span style="font-size:.6rem;opacity:.6;" x-text="sortIcon({{ col_i }})"></span></th>
                {% endfor %}
            </tr></thead>
            <tbody>
            {% for entry in audit_logs %}
            {% set when = (entry.get('createdAt') or '')[:16] | replace('T',' ') %}
            {% set user_obj = entry.get('user') %}
            {% if user_obj is mapping %}
            {% set user = user_obj.get('username') or '—' %}
            {% else %}
            {% set user = user_obj or '—' %}
            {% endif %}
            {% set cat = entry.get('category') or '—' %}
            {% set app_obj = entry.get('application') %}
            {% set app_name = app_obj.get('applicationName') if app_obj is mapping else '' %}
            {% set desc = entry.get('description') or '—' %}
            <tr class="tbl-row"
                data-search="{{ (user ~ ' ' ~ cat ~ ' ' ~ desc) | lower }}"
                data-sort-0="{{ when }}" data-sort-1="{{ user }}" data-sort-2="{{ cat }}" data-sort-3="{{ app_name }}" data-sort-4="{{ desc[:80] }}"
                x-show="search==='' || $el.dataset.search.includes(search.toLowerCase())">
                <td style="padding:10px 20px;font-size:.7rem;color:#4b5563;font-family:monospace;white-space:nowrap;">{{ when }}</td>
                <td style="padding:10px 20px;font-size:.75rem;color:#94a3b8;">{{ user }}</td>
                <td style="padding:10px 20px;">
                    <span style="display:inline-block;padding:2px 8px;border-radius:4px;font-size:.68rem;font-weight:700;color:#f97316;background:#f9731618;">{{ cat }}</span>
                </td>
                <td style="padding:10px 20px;font-size:.72rem;color:#6b7280;">{{ app_name or '—' }}</td>
                <td style="padding:10px 20px;font-size:.75rem;color:#6b7280;max-width:300px;">{{ desc }}</td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
        {% else %}
        <p style="padding:32px 20px;color:#4b5563;font-size:.85rem;text-align:center;">No audit log entries found.</p>
        {% endif %}
    </div>

</div>
{% endblock %}
